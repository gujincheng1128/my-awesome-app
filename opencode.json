{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "enabled": true,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "docker": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm", "-e", "DOCKER_HOST=tcp://host.docker.internal:2375", "mcp/docker"],
      "enabled": false
    },
    "postgres": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-postgres"],
      "enabled": true,
      "environment": {
        "DATABASE_URL": "${env:DATABASE_URL}"
      }
    },
    "tavily": {
      "type": "local",
      "command": ["npx", "-y", "tavily-mcp"],
      "enabled": true,
      "environment": {
        "TAVILY_API_KEY": "${env:TAVILY_API_KEY}"
      }
    },
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "E:/aimax/opencode/op/OpenCode/gz"],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "${env:CONTEXT7_API_KEY}"
      }
    },
    "obsidian": {
      "type": "local",
      "command": ["npx", "-y", "@connorbritain/obsidian-mcp-server"],
      "enabled": true,
      "environment": {
        "OBSIDIAN_VAULT_PATH": "${env:OBSIDIAN_VAULT_PATH}",
        "OBSIDIAN_API_KEY": "${env:OBSIDIAN_API_KEY}"
      }
    },
    "notion": {
      "type": "local",
      "command": ["npx", "-y", "@notionhq/notion-mcp-server"],
      "enabled": true,
      "environment": {
        "NOTION_TOKEN": "${env:NOTION_TOKEN}"
      }
    },
    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "enabled": true
    },
    "memos": {
      "type": "local",
      "command": ["npx", "-y", "memos-mcp"],
      "enabled": false,
      "environment": {
        "MEMOS_HOST": "${env:MEMOS_HOST}",
        "MEMOS_API_KEY": "${env:MEMOS_API_KEY}"
      }
    }
  },
  "skills": {
    "directory": "./.opencode/skills"
  }
}
